---
import { siteConfig } from '@/config';

interface Props {
  formId?: string;
  emailId?: string;
}

const { formId = 'subscribe-form', emailId = 'subscribe-email' } = Astro.props;
---

<h2 class="subscribe-modal__title" id={`${formId}-title`}>
  Never Miss a Post
</h2>
<p class="subscribe-modal__body">
  Subscribe to my blog to receive updates on my future posts, including but not limited to Power Pages and dev news, deep dives, and more. Zero spam, pure value.
</p>
<form
  action={siteConfig.mailchimp}
  method="post"
  id={formId}
  name={formId}
  class="validate"
  target="_blank"
  novalidate
>
  <input type="hidden" name="u" value={siteConfig.mailchimpU} />
  <input type="hidden" name="id" value={siteConfig.mailchimpId} />
  <div class="subscribe-modal__form-row">
    <input
      type="email"
      aria-label="Email address"
      name="MERGE0"
      id={emailId}
      placeholder="Enter your email address..."
      class="subscribe-modal__email"
      required
    />
    <input
      type="submit"
      value="Subscribe"
      name="subscribe"
      class="subscribe-modal__submit"
    />
  </div>
</form>
<p class="subscribe-modal__disclaimer">Unsubscribe any time</p>
