---
import Head from '@/components/Head.astro';
import Analytics from '@/components/Analytics.astro';
import '@/styles/main.scss';

import darkCssUrl from '@/styles/dark.scss?url';
import lightCssUrl from '@/styles/light.scss?url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <Head title={title} description={description} image={image} />
  <link rel="stylesheet" href={darkCssUrl} media="(prefers-color-scheme: dark)" />
  <link rel="stylesheet" href={lightCssUrl} media="(prefers-color-scheme: light)" />
  <body>
    <slot />
    <script is:inline>
      // Menu toggle
      document.addEventListener('DOMContentLoaded', function () {
        var flexContainer = document.querySelector('div.flex-container');
        var searchBox = document.querySelector('.search-box');
        var searchInput = document.getElementById('pagefind-search');

        // Menu open/close
        document.querySelectorAll('.menu-icon, .menu-icon-close').forEach(function (el) {
          el.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            if (flexContainer) flexContainer.classList.toggle('active');
          });
        });

        // Click outside menu to close
        if (flexContainer) {
          flexContainer.addEventListener('click', function (e) {
            if (flexContainer.classList.contains('active') && e.target.tagName !== 'A') {
              flexContainer.classList.remove('active');
            }
          });
        }

        // Escape key
        window.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            if (flexContainer && flexContainer.classList.contains('active')) {
              flexContainer.classList.remove('active');
            } else if (searchBox && searchBox.classList.contains('search-active')) {
              searchBox.classList.remove('search-active');
            }
          }
        });

        // Search toggle
        document.querySelectorAll('.search-icon').forEach(function (el) {
          el.addEventListener('click', function (e) {
            e.preventDefault();
            if (searchBox) {
              searchBox.classList.toggle('search-active');
              var input = searchBox.querySelector('input');
              if (input) input.focus();
            }
          });
        });

        document.querySelectorAll('.search-icon-close').forEach(function (el) {
          el.addEventListener('click', function (e) {
            e.preventDefault();
            if (searchBox) searchBox.classList.remove('search-active');
          });
        });
      });
    </script>
    <Analytics />
  </body>
</html>
