---
import Head from '@/components/Head.astro';
import Analytics from '@/components/Analytics.astro';
import HeaderInteractions from '@/components/HeaderInteractions.astro';
import '@/styles/main.scss';

import darkCssUrl from '@/styles/dark.scss?url';
import lightCssUrl from '@/styles/light.scss?url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <Head title={title} description={description} image={image} />
  <link rel="stylesheet" href={darkCssUrl} media="(prefers-color-scheme: dark)" />
  <link rel="stylesheet" href={lightCssUrl} media="(prefers-color-scheme: light)" />
  <body>
    <slot />
    <HeaderInteractions />
    <Analytics />
  </body>
</html>
